generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agent {
  id                  String           @id @default(uuid())
  email               String           @unique
  name                String
  avatarUrl           String?
  role                Role             @default(AGENT)
  isActive            Boolean          @default(true)
  status              AgentStatus      @default(ONLINE)
  maxConcurrentChats  Int              @default(5)
  googleId        String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  conversations   Conversation[]   @relation("AssignedAgent")
  messages        Message[]
  refreshTokens   RefreshToken[]
  segments        Segment[]
  createdTickets  Ticket[]         @relation("CreatedTickets")
  cannedResponses   CannedResponse[]
  notes             Note[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  followedConversations ConversationFollower[]
  escalationTeams       EscalationTeamMember[]

  @@index([email])
  @@index([googleId])
}

model CannedResponse {
  id        String   @id @default(uuid())
  agentId   String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

model Note {
  id             String       @id @default(uuid())
  conversationId Int
  agentId        String
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([agentId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  agentId   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([agentId])
}

model EndUser {
  id            String         @id @default(uuid())
  externalId    String         @unique
  name          String?
  email         String?
  phone         String?
  avatarUrl     String?
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]

  @@index([externalId])
  @@index([email])
}

model Conversation {
  id              Int                @id @default(autoincrement())
  userId          String
  categories      Category[]
  status          ConversationStatus @default(OPEN)
  isAiPaused      Boolean            @default(false)
  assignedAgentId String?
  priority        Priority           @default(MEDIUM)
  subject         String?
  queuedAt        DateTime?
  lastMessageAt      DateTime?
  lastReadByUserAt   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  ticketId        String?
  assignedAgent   Agent?             @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  ticket          Ticket?            @relation(fields: [ticketId], references: [id])
  user            EndUser            @relation(fields: [userId], references: [id])
  messages        Message[]
  tags            Tag[]
  notes           Note[]
  followers       ConversationFollower[]
  escalations     Escalation[]

  @@index([userId])
  @@index([status])
  @@index([assignedAgentId])
  @@index([ticketId])
  @@index([lastMessageAt])
  @@index([createdAt])
  @@index([isAiPaused])
  // Composite indexes for list query patterns:
  // single-column filters + ORDER BY lastMessageAt DESC
  @@index([status, lastMessageAt(sort: Desc)])
  @@index([assignedAgentId, lastMessageAt(sort: Desc)])
  @@index([userId, lastMessageAt(sort: Desc)])
  @@index([isAiPaused, lastMessageAt(sort: Desc)])
  // Two-column filter combos (my-issues: assignedAgent + status, live: status + isAiPaused)
  @@index([assignedAgentId, status, lastMessageAt(sort: Desc)])
  @@index([status, isAiPaused, lastMessageAt(sort: Desc)])
}

model Media {
  id        String   @id @default(uuid())
  url       String
  mimeType  String
  fileName  String
  createdAt DateTime @default(now())
  message   Message?
}

model Message {
  id             String       @id @default(uuid())
  conversationId Int
  senderType     SenderType
  senderId       String?
  content        String
  isStreaming    Boolean      @default(false)
  isPrivate      Boolean      @default(false)
  mediaId        String?      @unique
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent          Agent?       @relation(fields: [senderId], references: [id])
  media          Media?       @relation(fields: [mediaId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
  @@index([senderType])
  // Covers getConversationById: WHERE conversationId = ? ORDER BY createdAt ASC
  @@index([conversationId, createdAt])
}

model TagDefinition {
  id         String     @id @default(uuid())
  name       String     @unique
  color      String?
  categories Category[]
  createdAt  DateTime   @default(now())
  tags       Tag[]
}

model Tag {
  id             String        @id @default(uuid())
  conversationId Int
  definitionId   String
  source         TagSource     @default(AGENT)
  createdAt      DateTime      @default(now())
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  definition     TagDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([conversationId, definitionId, source])
  @@index([conversationId])
  @@index([definitionId])
  @@index([source])
}

model ConversationFollower {
  id             String       @id @default(uuid())
  conversationId Int
  agentId        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([conversationId, agentId])
  @@index([agentId])
  @@index([conversationId])
}

enum TagSource {
  AGENT
  AI
}

model Segment {
  id          String   @id @default(uuid())
  name        String
  description String?
  filters     Json
  createdById String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Agent    @relation(fields: [createdById], references: [id])

  @@index([createdById])
}

model Ticket {
  id              String         @id @default(uuid())
  title           String
  description     String?
  status          TicketStatus   @default(OPEN)
  priority        Priority       @default(MEDIUM)
  assignedAgentId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdById     String
  conversations   Conversation[]
  createdBy       Agent          @relation("CreatedTickets", fields: [createdById], references: [id])

  @@index([status])
  @@index([createdById])
  @@index([assignedAgentId])
}

model WorkspaceSetting {
  id                      String   @id @default("default")
  aiEnabled               Boolean  @default(true)
  queueMessage            String?
  ticketMessage           String?
  queueTimeoutMinutes     Int      @default(5)
  agentInactivityEnabled  Boolean  @default(true)
  agentInactivityHours    Int      @default(3)
  updatedAt               DateTime @updatedAt
}

model Notification {
  id             String           @id @default(uuid())
  agentId        String
  type           NotificationType
  title          String
  body           String
  conversationId Int?
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  agent          Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, isRead])
  @@index([agentId, createdAt])
}

model PushSubscription {
  id        String   @id @default(uuid())
  agentId   String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

model EscalationTeam {
  id          String                 @id @default(uuid())
  name        String                 @unique
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  members     EscalationTeamMember[]
  escalations Escalation[]
}

model EscalationTeamMember {
  id        String         @id @default(uuid())
  teamId    String
  agentId   String
  createdAt DateTime       @default(now())
  team      EscalationTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agent     Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([teamId, agentId])
  @@index([teamId])
  @@index([agentId])
}

model Escalation {
  id             String           @id @default(uuid())
  conversationId Int
  title          String
  teamId         String?
  categories     Category[]
  tagIds         String[]
  notes          String?
  dueDate        DateTime?
  status         EscalationStatus @default(OPEN)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  team           EscalationTeam?  @relation(fields: [teamId], references: [id])

  @@index([conversationId])
  @@index([teamId])
  @@index([status])
}

enum EscalationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  NEW_CONVERSATION
  NEW_MESSAGE
  ASSIGNED
  ESCALATED
}

enum Role {
  ADMIN
  AGENT
}

enum AgentStatus {
  ONLINE
  AWAY
  OFFLINE
}

enum SenderType {
  USER
  AI
  AGENT
}

enum Category {
  CARDS
  ACCOUNT
  SPENDS
  KYC
  GENERAL
  OTHER
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  ESCALATED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_USER
  RESOLVED
  CLOSED
}
