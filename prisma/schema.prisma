generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Agent {
  id              String           @id @default(uuid())
  email           String           @unique
  name            String
  avatarUrl       String?
  role            Role             @default(AGENT)
  isActive        Boolean          @default(true)
  googleId        String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  conversations   Conversation[]   @relation("AssignedAgent")
  messages        Message[]
  refreshTokens   RefreshToken[]
  segments        Segment[]
  createdTickets  Ticket[]         @relation("CreatedTickets")
  cannedResponses CannedResponse[]
  notes           Note[]

  @@index([email])
  @@index([googleId])
}

model CannedResponse {
  id        String   @id @default(uuid())
  agentId   String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

model Note {
  id             String       @id @default(uuid())
  conversationId String
  agentId        String
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([agentId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  agentId   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([agentId])
}

model EndUser {
  id            String         @id @default(uuid())
  externalId    String         @unique
  name          String?
  email         String?
  phone         String?
  avatarUrl     String?
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]

  @@index([externalId])
  @@index([email])
}

model Conversation {
  id              String             @id @default(uuid())
  userId          String
  category        Category           @default(GENERAL)
  status          ConversationStatus @default(OPEN)
  isAiPaused      Boolean            @default(false)
  assignedAgentId String?
  priority        Priority           @default(MEDIUM)
  subject         String?
  lastMessageAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  ticketId        String?
  assignedAgent   Agent?             @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  ticket          Ticket?            @relation(fields: [ticketId], references: [id])
  user            EndUser            @relation(fields: [userId], references: [id])
  messages        Message[]
  tags            Tag[]
  notes           Note[]

  @@index([userId])
  @@index([status])
  @@index([assignedAgentId])
  @@index([ticketId])
  @@index([lastMessageAt])
  @@index([createdAt])
  @@index([isAiPaused])
}

model Media {
  id        String   @id @default(uuid())
  url       String
  mimeType  String
  fileName  String
  createdAt DateTime @default(now())
  message   Message?
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderType     SenderType
  senderId       String?
  content        String
  isStreaming    Boolean      @default(false)
  mediaId        String?      @unique
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent          Agent?       @relation(fields: [senderId], references: [id])
  media          Media?       @relation(fields: [mediaId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
  @@index([senderType])
}

model TagDefinition {
  id        String   @id @default(uuid())
  type      String
  value     String
  label     String
  color     String?
  isSystem  Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  tags      Tag[]

  @@unique([type, value])
  @@index([type])
}

model Tag {
  id             String        @id @default(uuid())
  conversationId String
  definitionId   String
  confidence     Float?
  source         TagSource     @default(AI)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  definition     TagDefinition @relation(fields: [definitionId], references: [id])

  @@unique([conversationId, definitionId])
  @@index([conversationId])
  @@index([definitionId])
}

model Segment {
  id          String   @id @default(uuid())
  name        String
  description String?
  filters     Json
  createdById String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Agent    @relation(fields: [createdById], references: [id])

  @@index([createdById])
}

model Ticket {
  id              String         @id @default(uuid())
  title           String
  description     String?
  status          TicketStatus   @default(OPEN)
  priority        Priority       @default(MEDIUM)
  assignedAgentId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdById     String
  conversations   Conversation[]
  createdBy       Agent          @relation("CreatedTickets", fields: [createdById], references: [id])

  @@index([status])
  @@index([createdById])
  @@index([assignedAgentId])
}

model WorkspaceSetting {
  id        String   @id @default("default")
  aiEnabled Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  AGENT
}

enum SenderType {
  USER
  AI
  AGENT
}

enum Category {
  CARDS
  ACCOUNT
  SPENDS
  KYC
  GENERAL
  OTHER
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  ESCALATED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TagSource {
  AI
  AGENT
  SYSTEM
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_USER
  RESOLVED
  CLOSED
}
